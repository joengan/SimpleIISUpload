@using System.Text
@{
    Layout = null;
    Response.ContentType = "text/html";
    Response.ContentEncoding = Encoding.UTF8;
    Response.Charset = "utf-8";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>拒絕訪問 - 來源限制</title>
    <style>
        body {
            font-family: "Microsoft JhengHei", "PingFang TC", sans-serif;
            background-color: #f4f7f9;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 24px;
            box-sizing: border-box;
        }

        .container {
            text-align: center;
            background: white;
            padding: 3rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            max-width: 500px;
            width: 100%;
        }

        .icon {
            font-size: 64px;
            margin-bottom: 20px;
            color: #ff9800;
        }

        h1 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: #2c3e50;
        }

        p {
            line-height: 1.6;
            color: #666;
            margin-bottom: 2rem;
        }

        .contact-box {
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #3498db;
            font-size: 0.95rem;
        }

        .footer {
            margin-top: 2rem;
            font-size: 0.85rem;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="icon">🚫</div>
        <h1>拒絕訪問</h1>
        <p>感謝您的訪問。您的來源 IP 不在目前允許的清單內，因此暫時無法使用此上傳服務。</p>

        <div class="contact-box">
            如有使用需求或相關疑問，<br />
            <strong>請聯絡網站管理員</strong> 以確認是否需要加入允許清單。
        </div>

        <div class="footer">
            © 系統管理團隊
        </div>
    </div>
</body>
</html>
